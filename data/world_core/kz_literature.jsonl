{"id":"lit_076","kk":"Момышұлы — қазақ жазушысы әрі әскери қаһарман.","facts":[{"subject":"момышұлы","predicate":"is_a","object":"жазушы"},{"subject":"бауыржан","predicate":"is_a","object":"әскери"}],"domain":"kz_literature","source":"curated","confidence":"high","review_status":"approved","reviewer":"shaman","reviewed_at":"2026-04-26"}
