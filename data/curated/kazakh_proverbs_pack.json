{
  "version": "0.1.2",
  "name": "adam-kazakh-proverbs-pack",
  "target_language": "kazakh",
  "script": "cyrillic",
  "samples": [
    { "id": "proverb_001", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Білекті бірді жығады, білімді мыңды жығады." },
    { "id": "proverb_002", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Оқу — білім бұлағы, білім — өмір шырағы." },
    { "id": "proverb_003", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Кітап — білім бұлағы." },
    { "id": "proverb_004", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Білімсіз өмір — тұзсыз ас." },
    { "id": "proverb_005", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Ұстазсыз шәкірт болмас." },
    { "id": "proverb_006", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Оқыған озар, оқымаған тозар." },
    { "id": "proverb_007", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "knowledge", "text": "Ғылым — таусылмас қазына." },
    { "id": "proverb_008", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Еңбек ерлікке жеткізер, ерлік елдікке жеткізер." },
    { "id": "proverb_009", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Еңбек түбі — береке." },
    { "id": "proverb_010", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Еңбегіне қарай — өнбегі." },
    { "id": "proverb_011", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Еңбексіз өмір жоқ, өнерсіз күнкөріс жоқ." },
    { "id": "proverb_012", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Кім еңбек етсе, сол тояды." },
    { "id": "proverb_013", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "labor", "text": "Еңбекке бастаған, ерлікке жеткен." },
    { "id": "proverb_014", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "friendship", "text": "Досы көппен сыйлас, досы жоқпен сырлас." },
    { "id": "proverb_015", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "friendship", "text": "Ескі дос жау болмас." },
    { "id": "proverb_016", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "friendship", "text": "Дос басқа, дұшпан басқа." },
    { "id": "proverb_017", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "friendship", "text": "Жақсы дос — алтын күрек." },
    { "id": "proverb_018", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "friendship", "text": "Достық жоқ жерде — табыс жоқ." },
    { "id": "proverb_019", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Аз сөйлеп, көп тыңда." },
    { "id": "proverb_020", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Тіл — жүректің айнасы." },
    { "id": "proverb_021", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Сөз сүйектен өтер, таяқ еттен өтер." },
    { "id": "proverb_022", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Жақсы сөз — жарым ырыс." },
    { "id": "proverb_023", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Ойнап айтсаң да, ойлап айт." },
    { "id": "proverb_024", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Жақсы сөз — жан азығы." },
    { "id": "proverb_025", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "speech", "text": "Тілі татудың — ісі тату." },
    { "id": "proverb_026", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "homeland", "text": "Отан оттан да ыстық." },
    { "id": "proverb_027", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "homeland", "text": "Туған жердей жер болмас, туған елдей ел болмас." },
    { "id": "proverb_028", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "homeland", "text": "Ел — анаң, жер — атаң." },
    { "id": "proverb_029", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "homeland", "text": "Туған жер — тұғырың, туған ел — қорғаның." },
    { "id": "proverb_030", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "homeland", "text": "Ер туғанын сыйлар, ел туғанын қорғар." },
    { "id": "proverb_031", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "measure", "text": "Жеті өлшеп, бір кес." },
    { "id": "proverb_032", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "measure", "text": "Ойласып істеген іс өкінбейді." },
    { "id": "proverb_033", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "measure", "text": "Сабырлы жетер мұратына, сабырсыз қалар ұятына." },
    { "id": "proverb_034", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "unity", "text": "Бірлік бар жерде — тірлік бар." },
    { "id": "proverb_035", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "unity", "text": "Ынтымақ болмаған жерде — берекет болмас." },
    { "id": "proverb_036", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "unity", "text": "Көппен көрген — ұлы той." },
    { "id": "proverb_037", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "unity", "text": "Жеке жүрген ат озбас." },
    { "id": "proverb_038", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "character", "text": "Адамды адам жасайды." },
    { "id": "proverb_039", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "character", "text": "Ағаш тамырымен, адам атымен." },
    { "id": "proverb_040", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "character", "text": "Ар — адамның асыл қазынасы." },
    { "id": "proverb_041", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "character", "text": "Жаман адам дос болмас." },
    { "id": "proverb_042", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "character", "text": "Ақылды — жаманнан қашар, ақылсыз — жақсыдан қашар." },
    { "id": "proverb_043", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "patience", "text": "Сабыр түбі — сары алтын." },
    { "id": "proverb_044", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "patience", "text": "Асыққан шайтанның ісі." },
    { "id": "proverb_045", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "patience", "text": "Сабыр сақтағанның мақсаты асар." },
    { "id": "proverb_046", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "age_wisdom", "text": "Кәрінің тілін ал, жастың пілін." },
    { "id": "proverb_047", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "age_wisdom", "text": "Ақыл кеңестен туады." },
    { "id": "proverb_048", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "age_wisdom", "text": "Ақылды адам асықпас." },
    { "id": "proverb_049", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "truth", "text": "Ақиқат — тіршіліктің тірегі." },
    { "id": "proverb_050", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "truth", "text": "Шындық оттан да ыстық." },
    { "id": "proverb_051", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wealth", "text": "Байлық — бір жылдық, білім — мәңгілік." },
    { "id": "proverb_052", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wealth", "text": "Денсаулық — зор байлық." },
    { "id": "proverb_053", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wealth", "text": "Ынтымақ — халықтың байлығы." },
    { "id": "proverb_054", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "family", "text": "Ананың ақ сүтімен сіңген." },
    { "id": "proverb_055", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "family", "text": "Ананың қолы — бақ, әкенің қолы — тақ." },
    { "id": "proverb_056", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "family", "text": "Бала — елдің болашағы." },
    { "id": "proverb_057", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "family", "text": "Атаның ізінен ұл шығады." },
    { "id": "proverb_058", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "family", "text": "Ана — бала жанашыры." },
    { "id": "proverb_059", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "nature", "text": "Су бар жерде — тіршілік бар." },
    { "id": "proverb_060", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "nature", "text": "Жер — анасы, тіршіліктің бастауы." },
    { "id": "proverb_061", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "hospitality", "text": "Қонақ — үйдің берекесі." },
    { "id": "proverb_062", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "hospitality", "text": "Дастархан — достықтың нышаны." },
    { "id": "proverb_063", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "learning", "text": "Ұяда не көрсе, ұшқанда соны алады." },
    { "id": "proverb_064", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "learning", "text": "Білімсіз бір күн қараңғылықта өмір сүру." },
    { "id": "proverb_065", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "learning", "text": "Оқыған — озады, білімді — үздік болады." },
    { "id": "proverb_066", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "perseverance", "text": "Істің басы жеңіл, аяғы ауыр." },
    { "id": "proverb_067", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "perseverance", "text": "Талап — жетістіктің бастауы." },
    { "id": "proverb_068", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "perseverance", "text": "Еңбек — табыстың қайнары." },
    { "id": "proverb_069", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wisdom", "text": "Ақылды адам сөзін де, ісін де өлшеп айтар." },
    { "id": "proverb_070", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wisdom", "text": "Білгіш көптен озар, білімсіз жалғыз қалар." },
    { "id": "proverb_071", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "wisdom", "text": "Ой — адамның қаруы." },
    { "id": "proverb_072", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "health", "text": "Денсаулық — байлықтың басы." },
    { "id": "proverb_073", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "health", "text": "Ауруын жасырған — өлімге жақын." },
    { "id": "proverb_074", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "brevity", "text": "Аз да болса, саз болсын." },
    { "id": "proverb_075", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "brevity", "text": "Көп сөз — күміс, аз сөз — алтын." },
    { "id": "proverb_076", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "honor", "text": "Ар тазалығы — жанның тазалығы." },
    { "id": "proverb_077", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "honor", "text": "Жақсы есім — асыл қазына." },
    { "id": "proverb_078", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "community", "text": "Ағайын тату болса, ат көп." },
    { "id": "proverb_079", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "community", "text": "Ел ішінде — ер көп." },
    { "id": "proverb_080", "pack_name": "adam-kazakh-proverbs-pack", "source_id": "classical_kazakh_proverbs", "domain": "proverb", "theme": "courage", "text": "Ер қорықпас, ел жасымас." }
  ]
}
