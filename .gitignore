# External reference material (Apertium-kaz source repo, etc.) — 39+ MB each.
# We commit the DERIVED lexicon in data/lexicon_v1/, not the raw Apertium repo.
data/external/apertium/

# Derived corpus artifacts that exceed GitHub's 50 MB warning threshold.
# All regenerable from source packs via:
#   run_unified_corpus_assembly.sh → run_pretokenize_corpus.sh →
#   run_train_bpe.sh 8192 → run_encode_corpus.sh
data/curated/adam_training_corpus_pack.json
data/curated/adam_pretokenized_corpus_pack.json
data/curated/adam_training_ids_pack.json

# Wikipedia shard files 02+ (v1.3.5+). Only shard 01 lives at the
# canonical committed path `wikipedia_kz_pack.json`; the rest are
# local-only fuel for the v2.0 retrieval engine. Regenerate with
# `cargo run --release -p adam-corpus --bin process_wikipedia_kz -- --full`.
data/curated/shards/

# Full morpheme index (v1.6.0+). Only the committed-limit snapshot
# (data/retrieval/morpheme_index.json, built with --limit 500/pack)
# lives in git; the full-corpus build balloons to ~700 MB and is
# rebuildable via:
#   cargo run --release -p adam-retrieval --bin build_morpheme_index -- --full
data/retrieval/morpheme_index_full.json

# Checkpoints (regeneratable via `bash scripts/run_train_baseline.sh`).
# Each v0.4.0 checkpoint is ~92 MB. Distribute via release attachments if needed.
data/training/*.safetensors
data/training/*.safetensors.bak
data/training/*.safetensors.bak2
